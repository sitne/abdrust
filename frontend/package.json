{
  "name": "abdrust-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tunnel": "vite --host 0.0.0.0 --port 5173",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "lighthouse": "npm run build && lhci collect --config=./lighthouserc.cjs && lhci assert --config=./lighthouserc.cjs"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^1.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "axe-core": "^4.11.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
