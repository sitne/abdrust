# Discord Application
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://localhost
DISCORD_GUILD_ID=

# Local activity test mode: local or discord
ACTIVITY_MODE=local

# Server
HOST=0.0.0.0
PORT=3000

# Frontend build output
FRONTEND_DIST=../frontend/dist

# CORS
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=https://discord.com,https://canary.discord.com,https://ptb.discord.com

# Local activity guild id for websocket subscription
VITE_GUILD_ID=
